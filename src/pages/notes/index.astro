---
import Base from '../../layouts/Base.astro';
import NoteCard from '../../components/NoteCard.astro';
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS, formatDate } from '../../lib/site';

const notes = (await getCollection('notes', (e) => SHOW_DRAFTS || !e.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 300);

// Group by day, preserving order.
const days = new Map<string, typeof notes>();
for (const n of notes) {
  const day = formatDate(n.data.date);
  if (!days.has(day)) days.set(day, []);
  days.get(day)!.push(n);
}
---
<Base title="Notes" article={true}>
  <h1 class="page-title">Notes</h1>
  <p class="meta">links &amp; notes, newest first · <a href="/rss.xml">rss</a></p>

  {[...days.entries()].map(([day, dayNotes]) => (
    <section>
      <h2 class="day-header">{day}</h2>
      {dayNotes.map((n) => <NoteCard note={n} />)}
    </section>
  ))}
</Base>
