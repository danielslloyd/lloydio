---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { SHOW_DRAFTS, editUrl, formatDate } from '../../lib/site';

const notes = (await getCollection('notes', (e) => SHOW_DRAFTS || !e.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 300);

// Group by day, preserving order.
const days = new Map<string, typeof notes>();
for (const n of notes) {
  const day = formatDate(n.data.date);
  if (!days.has(day)) days.set(day, []);
  days.get(day)!.push(n);
}

const rendered = new Map<string, any>();
for (const n of notes) {
  const { Content } = await render(n);
  rendered.set(n.id, Content);
}
---
<Base title="Notes" article={true}>
  <h1 class="page-title">Notes</h1>
  <p class="meta">links &amp; notes, newest first · <a href="/rss.xml">rss</a></p>

  {[...days.entries()].map(([day, dayNotes]) => (
    <section>
      <h2 class="day-header">{day}</h2>
      {dayNotes.map((n) => {
        const Content = rendered.get(n.id);
        return (
          <article class="note" id={n.id}>
            <div class="note-title">
              {n.data.url ? (
                <a href={n.data.url}>{n.data.title ?? n.data.url}</a>
              ) : (
                (n.data.title ?? null)
              )}
              {n.data.archive && (
                <a class="archive-link" href={n.data.archive}>[archive]</a>
              )}
              {n.data.draft && <span class="draft-chip">draft</span>}
              {SHOW_DRAFTS && n.filePath && (
                <a class="edit-link" href={editUrl(n.filePath)}>edit</a>
              )}
            </div>
            {n.body?.trim() && (
              <div class="note-body">
                <Content />
              </div>
            )}
            {n.data.tags.length > 0 && (
              <div class="meta">
                {n.data.tags.map((t) => (
                  <a class="tag-chip" href={`/tags/${t}`}>#{t}</a>
                ))}
              </div>
            )}
          </article>
        );
      })}
    </section>
  ))}
</Base>
