---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../lib/site';

export async function getStaticPaths() {
  const showDrafts = process.env.DRAFTS === '1';
  const essays = await getCollection('essays', (e) => showDrafts || !e.data.draft);
  const notes = await getCollection('notes', (e) => showDrafts || !e.data.draft);
  const tags = new Set<string>();
  for (const e of [...essays, ...notes]) e.data.tags.forEach((t) => tags.add(t));
  return [...tags].map((tag) => ({
    params: { tag },
    props: {
      essays: essays.filter((e) => e.data.tags.includes(tag)),
      notes: notes.filter((n) => n.data.tags.includes(tag)),
    },
  }));
}

const { tag } = Astro.params;
const { essays, notes } = Astro.props;
const sortDesc = (a: any, b: any) => b.data.date.valueOf() - a.data.date.valueOf();
---
<Base title={`#${tag}`}>
  <h1 class="page-title">#{tag}</h1>
  {essays.length > 0 && (
    <>
      <h2>Essays</h2>
      <ul class="entry-list">
        {essays.sort(sortDesc).map((e) => (
          <li>
            <span class="entry-date">{formatDate(e.data.date)}</span>
            <a href={`/essays/${e.id}`}>{e.data.title}</a>
          </li>
        ))}
      </ul>
    </>
  )}
  {notes.length > 0 && (
    <>
      <h2>Notes</h2>
      <ul class="entry-list">
        {notes.sort(sortDesc).map((n) => (
          <li>
            <span class="entry-date">{formatDate(n.data.date)}</span>
            {n.data.url
              ? <a href={n.data.url}>{n.data.title ?? n.data.url}</a>
              : <a href={`/notes#${n.id}`}>{n.data.title ?? 'note'}</a>}
          </li>
        ))}
      </ul>
    </>
  )}
</Base>
