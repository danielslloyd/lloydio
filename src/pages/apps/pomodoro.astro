---
import Base from '../../layouts/Base.astro';
---
<Base title="Pomodoro">
  <h1 class="page-title">Pomodoro Schedule</h1>

  <div style="display: flex; justify-content: space-between; align-items: center; margin: 2rem 0;">
    <div style="font-size: 2.5rem; font-variant-numeric: tabular-nums;" id="clock">00:00</div>
    <div style="display: flex; gap: 0.5rem;">
      <label><input type="checkbox" id="chime-half" checked /> chime at :00 & :30</label>
      <label><input type="checkbox" id="chime-quarter" /> tick at :10, :20, :40, :50</label>
    </div>
  </div>

  <div class="grid-scroll" id="grid-scroll">
    <table>
      <thead>
        <tr>
          <th style="text-align: left;">Time</th>
          <th style="text-align: left;">Task</th>
        </tr>
      </thead>
      <tbody id="schedule-grid"></tbody>
    </table>
  </div>

  <style>
    /* Scrolling box that never stretches the page. */
    .grid-scroll {
      position: relative;
      max-height: 65vh;
      overflow-y: auto;
      border: 1px solid var(--border);
    }
    /* The rows/cells are built in JS, so these must be :global to match
       (dynamic nodes don't carry Astro's scoped-style attribute). */
    .grid-scroll :global(table) { width: 100%; border-collapse: collapse; }
    .grid-scroll :global(thead th) {
      position: sticky;
      top: 0;
      z-index: 2;
      background: var(--bg);
      padding: 0.5rem;
      text-align: left;
      font-weight: 600;
      border-bottom: 2px solid var(--border);
    }
    .grid-scroll :global(tbody tr) { border-bottom: 1px solid var(--border); }
    .grid-scroll :global(td) { padding: 0.6rem 0.5rem; }
    .grid-scroll :global(.time-cell) {
      text-align: right;
      color: var(--muted);
      font-size: 0.9rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
    }
    .grid-scroll :global(input) {
      width: 100%;
      padding: 0.4rem;
      border: 1px solid var(--border);
      background: var(--bg);
      color: var(--fg);
      font-family: inherit;
    }
    .grid-scroll :global(input:focus) { outline: 2px solid var(--fg); outline-offset: -1px; }

    /* Past slots: grayed out. */
    .grid-scroll :global(tr.past .time-cell) { color: var(--faint); }
    .grid-scroll :global(tr.past input) { opacity: 0.45; }

    /* Current slot: subtle highlight + a thin progress bar along the bottom
       showing how far through the 30-minute window we are. */
    .grid-scroll :global(tr.current) {
      background:
        linear-gradient(to right, var(--fg) var(--progress, 0%), transparent 0) bottom / 100% 2px no-repeat,
        var(--surface);
    }
    .grid-scroll :global(tr.current .time-cell) { color: var(--fg); font-weight: 600; }
  </style>

  <script is:inline>
    const $ = (id) => document.getElementById(id);
    const clockEl = $('clock');
    const gridEl = $('schedule-grid');
    const scrollBox = $('grid-scroll');
    const chimeHalf = $('chime-half');
    const chimeQuarter = $('chime-quarter');

    let lastChimeTime = -1;
    let didInitialScroll = false;

    // minutes-since-midnight for a slot / for "now"
    const slotStart = (h, m) => h * 60 + m;

    function generateGrid() {
      gridEl.innerHTML = '';
      for (let h = 0; h < 24; h++) {
        for (let m = 0; m < 60; m += 30) {
          const timeStr = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0');
          const savedTask = localStorage.getItem('pomo-task-' + timeStr) || '';
          const tr = document.createElement('tr');
          tr.dataset.start = String(slotStart(h, m));
          tr.innerHTML =
            '<td class="time-cell">' + timeStr + '</td>' +
            '<td><input type="text" class="task-input" data-time="' + timeStr +
            '" value="' + savedTask.replace(/"/g, '&quot;') + '" placeholder="Task..." /></td>';
          gridEl.appendChild(tr);
        }
      }
      document.querySelectorAll('.task-input').forEach((input) => {
        input.addEventListener('change', (e) => {
          localStorage.setItem('pomo-task-' + e.target.getAttribute('data-time'), e.target.value);
        });
      });
    }

    // Mark past / current slots and update the current slot's progress bar.
    function updateGridState() {
      const now = new Date();
      const mins = now.getHours() * 60 + now.getMinutes() + now.getSeconds() / 60;
      let currentRow = null;
      gridEl.querySelectorAll('tr').forEach((tr) => {
        const start = Number(tr.dataset.start);
        const end = start + 30;
        tr.classList.remove('past', 'current');
        if (end <= mins) {
          tr.classList.add('past');
        } else if (start <= mins && mins < end) {
          tr.classList.add('current');
          tr.style.setProperty('--progress', (((mins - start) / 30) * 100).toFixed(1) + '%');
          currentRow = tr;
        }
      });
      return currentRow;
    }

    // Put the current slot ~1/3 of the way down the scroll box.
    function scrollToCurrent(row) {
      if (!row) return;
      scrollBox.scrollTop = row.offsetTop - scrollBox.clientHeight / 3;
    }

    function playChime(freq = 660, duration = 0.8) {
      try {
        const ctx = new (window.AudioContext || window.webkitAudioContext)();
        const o = ctx.createOscillator();
        const g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.frequency.value = freq;
        g.gain.setValueAtTime(0.15, ctx.currentTime);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + duration);
        o.start();
        o.stop(ctx.currentTime + duration);
      } catch {}
    }

    function tick() {
      const now = new Date();
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      const s = String(now.getSeconds()).padStart(2, '0');
      clockEl.textContent = h + ':' + m + ':' + s;

      const minute = now.getMinutes();
      const second = now.getSeconds();
      if (chimeHalf.checked && second === 0 && (minute === 0 || minute === 30) && lastChimeTime !== minute) {
        lastChimeTime = minute;
        playChime(660, 0.8);
      }
      if (chimeQuarter.checked && second === 0 && [10, 20, 40, 50].includes(minute) && lastChimeTime !== minute) {
        lastChimeTime = minute;
        playChime(880, 0.3);
      }

      const currentRow = updateGridState();
      if (!didInitialScroll && currentRow) {
        scrollToCurrent(currentRow);
        didInitialScroll = true;
      }
    }

    generateGrid();
    tick();
    setInterval(tick, 1000);
  </script>
</Base>
