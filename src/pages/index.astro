---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { SHOW_DRAFTS, formatDate } from '../lib/site';

const essays = (await getCollection('essays', (e) => SHOW_DRAFTS || !e.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 5);
const notes = (await getCollection('notes', (e) => SHOW_DRAFTS || !e.data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 8);
---
<Base>
  <h1 class="page-title">lloydio</h1>
  <p>
    Notes, links, essays, and small tools. This site doubles as a daily dumping
    ground — see the <a href="/notes">notes</a> for the raw feed, or the
    distilled shelves: an article <a href="/reading">reading list</a> (with
    narrated audio), <a href="/books">books</a>,
    a <a href="/commonplace">commonplace book</a>,
    <a href="/beautiful">beautiful things</a>, and
    <a href="/infographics">infographics</a>.
  </p>

  <h2>Recent notes</h2>
  <ul class="entry-list">
    {notes.map((n) => (
      <li>
        <span class="entry-date">{formatDate(n.data.date)}</span>
        <span>
          {n.data.url
            ? <a href={n.data.url}>{n.data.title ?? n.data.url}</a>
            : <a href={`/notes#${n.id}`}>{n.data.title ?? 'note'}</a>}
          {n.data.draft && <span class="draft-chip">draft</span>}
        </span>
      </li>
    ))}
  </ul>
  <p><a href="/notes">all notes →</a></p>

  <h2>Essays</h2>
  <ul class="entry-list">
    {essays.map((e) => (
      <li>
        <span class="entry-date">{formatDate(e.data.date)}</span>
        <span>
          <a href={`/essays/${e.id}`}>{e.data.title}</a>
          {e.data.draft && <span class="draft-chip">draft</span>}
        </span>
      </li>
    ))}
  </ul>
</Base>
