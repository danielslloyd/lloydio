  },
  // original single-path (simple-icons): M.045 18.02c.072-.116…
  amazon: {
    viewBox: '4.49 0.44 247.41 254.97',
    inner:
      '<path d="m221.503 210.324c-105.235 50.083-170.545 8.18-212.352-17.271-2.587-1.604-6.984.375-3.169 4.757 13.928 16.888 59.573 57.593 119.153 57.593 59.621 0 95.09-32.532 99.527-38.207 4.407-5.627 1.294-8.731-3.16-6.872zm29.555-16.322c-2.826-3.68-17.184-4.366-26.22-3.256-9.05 1.078-22.634 6.609-21.453 9.93.606 1.244 1.843.686 8.06.127 6.234-.622 23.698-2.826 27.337 1.931 3.656 4.79-5.57 27.608-7.255 31.288-1.628 3.68.622 4.629 3.68 2.178 3.016-2.45 8.476-8.795 12.14-17.774 3.639-9.028 5.858-21.622 3.71-24.424z" fill="#f90" fill-rule="nonzero"/><path d="m150.744 108.13c0 13.141.332 24.1-6.31 35.77-5.361 9.489-13.853 15.324-23.341 15.324-12.952 0-20.495-9.868-20.495-24.432 0-28.75 25.76-33.968 50.146-33.968zm34.015 82.216c-2.23 1.992-5.456 2.135-7.97.806-11.196-9.298-13.189-13.615-19.356-22.487-18.502 18.882-31.596 24.527-55.601 24.527-28.37 0-50.478-17.506-50.478-52.565 0-27.373 14.85-46.018 35.96-55.126 18.313-8.066 43.884-9.489 63.43-11.718v-4.365c0-8.018.616-17.506-4.08-24.432-4.128-6.215-12.003-8.777-18.93-8.777-12.856 0-24.337 6.594-27.136 20.257-.57 3.037-2.799 6.026-5.835 6.168l-32.735-3.51c-2.751-.618-5.787-2.847-5.028-7.07 7.543-39.66 43.36-51.616 75.43-51.616 16.415 0 37.858 4.365 50.81 16.795 16.415 15.323 14.849 35.77 14.849 58.02v52.565c0 15.798 6.547 22.724 12.714 31.264 2.182 3.036 2.657 6.69-.095 8.966-6.879 5.74-19.119 16.415-25.855 22.393l-.095-.095" fill="#000" fill-rule="evenodd"/>',
  },
  // original single-path (simple-icons): M12.008 17.362L24 9.885…
  audible: {
    viewBox: '0 -0.01 1333.33 828.85',
    inner:
      '<path d="M666.66 715.71l666.67-418.69v113.09L666.66 828.84 0 410.11V297.02l666.66 418.69zm-.18-523.5c150.16 0 282.43 76.98 359.89 193.83h-.11l-98.13 61.68c-147.61-197.58-417.65-231.81-604.72-75.96-5.49 4.56-10.79 9.28-16.02 14.05l-.61-.07c77.46-116.67 209.65-193.54 359.7-193.54zm0 192.21c81.75 0 154 40.97 197.53 103.57h-.04l-94.67 59.48c-44.14-61.09-108.44-99.62-180.05-99.62-43.56 0-84.36 14.29-119.64 39.15 43.64-62.04 115.54-102.57 196.88-102.57zm-450.6-168.84c-23.98 19.07-50.72 46.42-71.35 68.25C256.82 111.95 450.94-.01 666.44-.01c218.62 0 410.9 113.06 522.23 284.25v-.04l-101.62 63.61-1.39-2.11C878.8 55.69 490.35-2.81 215.88 215.59z" fill="#f7991c"/>',
  },
};

const shops = (['goodreads', 'amazon', 'audible'] as const)
  .filter((k) => links[k])
  .map((k) => ({ kind: k, url: links[k]!, specific: isSpecific(links[k]!, k) }));
---

<tr class="book-row">
  <td class="book-cover">
    {cover && (
      <img src={cover} alt="" loading="lazy" class="cover-image" onerror="this.remove()" />
    )}
  </td>
  <td class="book-title-author">
    <div class="title" title={title}>{truncateTitle(title)}</div>
    <div class="author">{author}</div>
    {review && (
      <details class="book-review">
        <summary>review</summary>
        <div class="review-body">{review}</div>
      </details>
    )}
  </td>
  <td class="book-status" title={`Added ${formatDate(date)}`}>
    {showStars ? (
      rating ? (
        <span class="stars" title={`${rating}/5`}>{stars(rating)}</span>
      ) : (
        <span class="stars empty" title="unrated">☆☆☆☆☆</span>
      )
    ) : (
      <span class="status">{status}</span>
    )}
  </td>
  <td class="book-links">
    {shops.map((s) => (
      <a
        href={s.url}
        title={`${s.kind[0].toUpperCase()}${s.kind.slice(1)}${s.specific ? '' : ' (search)'}`}
        class:list={['shop', s.kind, { search: !s.specific }]}
      >
        <svg class="icon" viewBox={LOGO[s.kind].viewBox} fill="currentColor" aria-hidden="true" set:html={LOGO[s.kind].inner} />
      </a>
    ))}
  </td>
</tr>

<style>
  .book-cover {
    width: 44px;
    padding: 0.3em !important;
    text-align: center;
  }
  .cover-image {
    max-width: 100%;
    max-height: 64px;
    border: 1px solid var(--border);
  }

  .book-title-author {
    text-align: left;
  }
  .title {
    font-weight: 600;
    line-height: 1.3;
  }
  .author {
    color: var(--muted);
    font-size: 0.9em;
    margin-top: 0.1em;
  }
  .book-review {
    margin: 0.35em 0 0;
    border: none;
    padding: 0;
  }
  .book-review summary {
    cursor: pointer;
    color: var(--faint);
    font-size: 0.8em;
    font-variant: small-caps;
    letter-spacing: 0.03em;
    list-style: none;
  }
  .book-review summary::-webkit-details-marker { display: none; }
  .book-review summary::before { content: '▸ '; }
  .book-review[open] summary::before { content: '▾ '; }
  .book-review[open] summary { color: var(--muted); }
  .review-body {
    margin-top: 0.35em;
    font-size: 0.9em;
    color: var(--fg);
    font-weight: 400;
    line-height: 1.5;
  }

  .book-status {
    text-align: center;
    font-size: 0.9em;
    white-space: nowrap;
  }
  .stars {
    letter-spacing: -0.1em;
  }
  /* "read" with no rating: five empty stars in the icon gray. */
  .stars.empty {
    color: var(--faint);
  }
  .status {
    color: var(--muted);
    font-variant: small-caps;
  }

  .book-links {
    white-space: nowrap;
    text-align: center;
  }
  .shop {
    display: inline-block;
    margin: 0 0.18em;
    line-height: 1;
    text-decoration: none;
  }
  /* Same square box for every logo; wide/tall marks letterbox within it
     (preserveAspectRatio meet) rather than changing the box size. */
  .icon {
    width: 1.15em;
    height: 1.15em;
    vertical-align: -0.2em;
  }

  /* Goodreads is a currentColor mark; Amazon/Audible carry brand fills. */
  .shop.goodreads { color: #553b08; }
  :root[data-theme='dark'] .shop.goodreads { color: #c9a06a; }
  /* Keep the black Amazon wordmark visible on dark backgrounds. */
  :root[data-theme='dark'] .shop .icon :global(path[fill='#000']) { fill: var(--fg); }

  /* Search links: grayed out (override the baked-in fills). */
  .shop.search { opacity: 0.65; }
  .shop.search .icon,
  .shop.search .icon :global(path) { color: var(--faint); fill: var(--faint); }
  .shop:hover { opacity: 1; }
</style>
