---
import { formatDate } from '../lib/site';

interface Props {
  id: string;
  title: string;
  author: string;
  status: 'to-read' | 'reading' | 'finished';
  rating?: number;
  date: Date;
  cover?: string;
  review?: string;
  links: {
    goodreads?: string;
    amazon?: string;
    audible?: string;
  };
}

const { title, author, status, rating, date, cover, review, links } = Astro.props;

const stars = (n?: number) => (n ? '★'.repeat(n) + '☆'.repeat(5 - n) : '');

// Keep long titles to a single line; the ellipsis only earns its place when it
// hides more than one character.
const truncateTitle = (str: string, maxLen = 42) =>
  str.length > maxLen + 1 ? str.slice(0, maxLen).trimEnd() + '…' : str;

const showStars = status !== 'to-read' && status !== 'reading';

// A "live/specific" link points at one product; a search link just runs a
// keyword query. Specific links show in brand color, search links are grayed.
const isSpecific = (url: string, kind: 'goodreads' | 'amazon' | 'audible') => {
  if (kind === 'goodreads') return url.includes('/book/show/');
  if (kind === 'amazon') return url.includes('/dp/') || url.includes('/gp/');
  // Audiobook edition: audible.com/pd/… or the Amazon "Audible Audio Edition"
  // page (…/dp/…). Anything with a keyword query is just a search.
  if (kind === 'audible') return !/[?&]keywords=|\/search\b/.test(url);
  return false;
};

// Real brand marks (simple-icons, MIT). Rendered at text height with
// currentColor so the color/gray state is pure CSS.
