const shops = (['goodreads', 'amazon', 'audible'] as const)
  .filter((k) => links[k])
  .map((k) => ({ kind: k, url: links[k]!, specific: isSpecific(links[k]!, k) }));
---

<tr class="book-row">
  <td class="book-cover">
    {cover && (
      <img src={cover} alt="" loading="lazy" class="cover-image" onerror="this.remove()" />
    )}
  </td>
  <td class="book-title-author">
    <div class="title" title={title}>{truncateTitle(title)}</div>
    <div class="author">{author}</div>
  </td>
  <td class="book-status" title={`Added ${formatDate(date)}`}>
    {showStars ? (
      <span class="stars" title={rating ? `${rating}/5` : 'unrated'}>{stars(rating)}</span>
    ) : (
      <span class="status">{status}</span>
    )}
  </td>
  <td class="book-links">
    {shops.map((s) => (
      <a
        href={s.url}
        title={`${s.kind[0].toUpperCase()}${s.kind.slice(1)}${s.specific ? '' : ' (search)'}`}
        class:list={['shop', s.kind, { search: !s.specific }]}
      >
        <svg class="icon" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d={LOGO[s.kind]} />
        </svg>
      </a>
    ))}
  </td>
</tr>

<style>
  .book-cover {
    width: 44px;
    padding: 0.3em !important;
    text-align: center;
  }
  .cover-image {
    max-width: 100%;
    max-height: 64px;
    border: 1px solid var(--border);
  }

  .book-title-author {
    text-align: left;
  }
  .title {
    font-weight: 600;
    line-height: 1.3;
  }
  .author {
    color: var(--muted);
    font-size: 0.9em;
    margin-top: 0.1em;
  }

  .book-status {
    text-align: center;
    font-size: 0.9em;
    white-space: nowrap;
  }
  .stars {
    letter-spacing: -0.1em;
  }
  .status {
    color: var(--muted);
    font-variant: small-caps;
  }

  .book-links {
    white-space: nowrap;
    text-align: center;
  }
  .shop {
    display: inline-block;
    margin: 0 0.18em;
    line-height: 1;
    text-decoration: none;
  }
  .icon {
    width: 1.05em;
    height: 1.05em;
    vertical-align: -0.15em;
  }

  /* Brand colors for live/specific links. */
  .shop.goodreads { color: #553b08; }
  .shop.amazon { color: #ff9900; }
  .shop.audible { color: #f8991c; }
  :root[data-theme='dark'] .shop.goodreads { color: #c9a06a; }

  /* Search links: grayed out. */
  .shop.search {
    color: var(--faint);
    opacity: 0.65;
  }
  .shop:hover { opacity: 1; }
</style>
